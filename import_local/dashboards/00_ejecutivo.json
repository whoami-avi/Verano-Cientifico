    {
      "id": 9,
      "type": "piechart",
      "title": "Diagn\u00f3stico: Competente vs No Competente",
      "description": "",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "see_pg"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "see_pg"
          },
          "rawSql": "SELECT max(CASE WHEN estado='Competente' THEN empleados END) AS \"Competente\", max(CASE WHEN estado='No competente' THEN empleados END) AS \"No competente\" FROM rep_ddn",
          "editorMode": "code",
          "rawQuery": true
        }
      ],
      "fieldConfig": {
