    {
      "id": 4,
      "type": "stat",
      "title": "% Cumplimiento Competencias",
      "description": "",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "see_pg"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "see_pg"
          },
          "rawSql": "WITH ult AS (SELECT DISTINCT ON (no_reloj, id_competencia) * FROM diagnosticos ORDER BY no_reloj, id_competencia, fecha_registro DESC) SELECT round(100.0*sum(CASE WHEN ult.competente THEN 1 ELSE 0 END)/nullif(count(*),0),1) FROM ult JOIN empleados e ON ult.no_reloj=e.no_reloj WHERE e.clave_planta IN ($planta) AND e.id_departamento IN ($departamento)",
          "editorMode": "code",
          "rawQuery": true
