            "type": "postgres",
            "uid": "see_pg"
          },
          "rawSql": "SELECT round(100.0*count(*) FILTER (WHERE (fecha_aprobacion-fecha_envio)<=3)/nullif(count(*) FILTER (WHERE autorizada),0),1) FROM descripciones_puesto",
