    {
      "id": 3,
      "type": "table",
      "title": "Resumen por Planta",
      "description": "",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "see_pg"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "see_pg"
          },
          "rawSql": "WITH ult AS (SELECT DISTINCT ON (no_reloj, id_competencia) * FROM diagnosticos ORDER BY no_reloj, id_competencia, fecha_registro DESC) SELECT pl.planta AS \"Planta\", pl.ubicacion AS \"Ubicacion\", count(DISTINCT e.no_reloj) AS \"Empleados\", count(*) AS \"Evaluaciones\", round(100.0*sum(CASE WHEN ult.competente THEN 1 ELSE 0 END)/nullif(count(*),0),1) AS \"% Cumplimiento\" FROM ult JOIN empleados e ON ult.no_reloj=e.no_reloj JOIN plantas pl ON e.clave_planta=pl.clave_planta GROUP BY pl.planta, pl.ubicacion ORDER BY \"% Cumplimiento\" DESC",
          "editorMode": "code",
          "rawQuery": true
        }
      ],
