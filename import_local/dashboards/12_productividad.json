      "title": "Tiempo por Proceso: Antes vs Despues (minutos)",
      "description": "",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "see_pg"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "see_pg"
          },
          "rawSql": "SELECT proceso AS \"Proceso\", tiempo_antes_min AS \"Antes (manual)\", tiempo_despues_min AS \"Despues (SEE)\" FROM metricas_productividad ORDER BY tiempo_antes_min DESC",
