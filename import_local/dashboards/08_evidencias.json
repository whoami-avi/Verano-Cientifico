          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "see_pg"
          },
          "rawSql": "WITH ult AS (SELECT DISTINCT ON (no_reloj, id_competencia) * FROM diagnosticos ORDER BY no_reloj, id_competencia, fecha_registro DESC) SELECT round(100.0*count(*) FILTER (WHERE ruta_evidencia IS NOT NULL)/nullif(count(*) FILTER (WHERE competente),0),1) FROM ult",
