    {
      "id": 7,
      "type": "timeseries",
      "title": "Tendencia Anual de Cumplimiento del Plan Maestro",
      "description": "",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "see_pg"
      },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "see_pg"
          },
          "rawSql": "SELECT make_date(anio_fiscal,1,1) AS \"time\", round(100.0*count(*) FILTER (WHERE estatus='Completado')/nullif(count(*) FILTER (WHERE estatus<>'Cancelado'),0),1) AS \"% Cumplimiento Plan Maestro\" FROM cursos_programados GROUP BY anio_fiscal ORDER BY anio_fiscal",
          "editorMode": "code",
          "rawQuery": true
        }
      ],
