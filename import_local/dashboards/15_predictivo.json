      "type": "stat",
      "title": "Competencias por Vencer (30 dias)",
      "description": "",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "see_pg"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "see_pg"
          },
          "rawSql": "WITH ult AS (SELECT DISTINCT ON (no_reloj, id_competencia) * FROM diagnosticos ORDER BY no_reloj, id_competencia, fecha_registro DESC) SELECT count(*) FROM ult WHERE competente AND fecha_vencimiento BETWEEN now() AND now() + interval '30 days'",
          "editorMode": "code",
          "rawQuery": true
        }
      ],
