    {
      "id": 2,
      "type": "gauge",
      "title": "Documentos Controlados (DDP Autorizadas)",
      "description": "",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "see_pg"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "see_pg"
          },
          "rawSql": "SELECT round(100.0*sum(CASE WHEN autorizada THEN 1 ELSE 0 END)/nullif(count(*),0),1) FROM descripciones_puesto",
          "editorMode": "code",
          "rawQuery": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
