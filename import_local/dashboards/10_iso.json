      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "see_pg"
          },
          "rawSql": "SELECT date_trunc('month', fecha_creacion)::date AS \"time\", count(*) AS \"DDP creadas\" FROM descripciones_puesto WHERE $__timeFilter(fecha_creacion) GROUP BY 1 ORDER BY 1",
          "editorMode": "code",
