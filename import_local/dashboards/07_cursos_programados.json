      "type": "marcusolsson-calendar-panel",
      "title": "Calendario Anual de Cursos (2026)",
      "description": "Vista de calendario de los cursos programados",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "see_pg"
