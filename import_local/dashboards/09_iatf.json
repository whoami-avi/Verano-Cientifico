    {
      "id": 5,
      "type": "bargauge",
      "title": "Cumplimiento por Competencia Normativa (%)",
      "description": "",
      "datasource": {
        "type": "postgres",
        "uid": "see_pg"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "datasource": {
            "type": "postgres",
            "uid": "see_pg"
          },
          "rawSql": "WITH ult AS (SELECT DISTINCT ON (no_reloj, id_competencia) * FROM diagnosticos ORDER BY no_reloj, id_competencia, fecha_registro DESC) SELECT cp.descripcion_competencia AS metric, round(100.0*sum(CASE WHEN ult.competente THEN 1 ELSE 0 END)/nullif(count(*),0),1) AS value FROM ult JOIN competencias_puesto cp ON ult.id_competencia=cp.id_competencia WHERE cp.tipo='Normativa' GROUP BY cp.descripcion_competencia ORDER BY value DESC",
          "editorMode": "code",
          "rawQuery": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "mappings": [],
          "thresholds": {
