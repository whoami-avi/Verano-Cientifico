    {
      "id": 2,
      "type": "piechart",
      "title": "Brechas por Prioridad",
      "description": "",
      "datasource": {
        "type": "postgres",
        "uid": "see_pg"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "datasource": {
            "type": "postgres",
            "uid": "see_pg"
          },
          "rawSql": "WITH ult AS (SELECT DISTINCT ON (no_reloj, id_competencia) * FROM diagnosticos ORDER BY no_reloj, id_competencia, fecha_registro DESC) SELECT prioridad AS metric, count(*) AS value FROM ult WHERE NOT competente GROUP BY prioridad",
          "editorMode": "code",
          "rawQuery": true
        }
