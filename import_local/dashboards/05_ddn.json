    {
      "id": 3,
      "type": "stat",
      "title": "Diagnosticos No Competentes (Prioridad Alta)",
      "description": "",
      "datasource": {
        "type": "postgres",
        "uid": "see_pg"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "datasource": {
            "type": "postgres",
            "uid": "see_pg"
          },
          "rawSql": "WITH ult AS (SELECT DISTINCT ON (no_reloj, id_competencia) * FROM diagnosticos ORDER BY no_reloj, id_competencia, fecha_registro DESC) SELECT count(*) FROM ult WHERE NOT competente AND prioridad='Alta'",
          "editorMode": "code",
          "rawQuery": true
        }
      ],
      "fieldConfig": {
